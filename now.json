{
    "version": 2,
    "routes": [
        {
            "src": "^/service-worker.js$",
            "dest": "/_next/static/service-worker.js",
            "headers": {
                "cache-control": "public, max-age=43200, immutable",
                "Service-Worker-Allowed": "/"
            }
        },
        {
            "source": "/(.*)",
            "headers" : [
                {
                    "key" : "X-Content-Type-Options",
                    "value" : "nosniff"
                },
                {
                    "key" : "X-Frame-Options",
                    "value" : "DENY"
                },
                {
                    "key" : "X-XSS-Protection",
                    "value" : "1; mode=block"
                }
            ]
        }
    ],
    "builds": [
        {
            "src": "next.config.js",
            "use": "@now/next"
        }
    ]
}
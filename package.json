{
  "name": "alkitab-mini-app",
  "description": "Alkitab Mini web app.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/zeit/now/tree/master/examples/nextjs"
  },
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm build:sw && next build --turbopack",
    "build:sw": "esbuild src/service-worker/sw.js --bundle --outfile=public/sw.js --minify --target=es2015",
    "start": "next start",
    "analyze": "ANALYZE=true pnpm build --webpack",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@huggingface/transformers": "^3.8.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "animejs": "^4.3.6",
    "autoprefixer": "^10.4.27",
    "core-js": "^3.49.0",
    "kokoro-js": "^1.2.1",
    "next": "latest",
    "postcss": "^8.5.8",
    "react": "latest",
    "react-dom": "latest",
    "regenerator-runtime": "^0.14.1",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/bundle-analyzer": "^16.2.1",
    "esbuild": "0.27.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "path-browserify": "^1.0.1",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.32.1"
}
